<opnsense>
  <version>26.1.6</version>
  <lastchange/>
  <system>
    <optimization>normal</optimization>
    <hostname>fw01</hostname>
    <domain>home.local</domain>
    <dnsallowoverride>1</dnsallowoverride>
    <dnsallowoverride_exclude/>
