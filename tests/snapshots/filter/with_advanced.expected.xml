      <rule uuid="b2eed548-ee1b-5ef5-a226-ee63838e0e76">
        <enabled>1</enabled>
        <sequence>20</sequence>
        <action>pass</action>
        <quick>1</quick>
        <interface>lan</interface>
        <direction>in</direction>
        <ipprotocol>inet</ipprotocol>
        <protocol>tcp</protocol>
        <source_net>10.0.0.0/8</source_net>
        <source_not>0</source_not>
        <destination_net>192.168.1.100</destination_net>
        <destination_not>0</destination_not>
        <destination_port>443</destination_port>
        <log>0</log>
