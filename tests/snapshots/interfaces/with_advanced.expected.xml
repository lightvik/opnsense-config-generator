<interfaces>
  <wan>
    <enable>1</enable>
    <descr>WAN</descr>
    <if>em0</if>
    <mtu>1500</mtu>
    <mss>1460</mss>
    <gateway_interface/>
    <ipaddr>dhcp</ipaddr>
    <dhcphostname></dhcphostname>
    <dhcphonourmtu/>
    <dhcp6-ia-pd-len>0</dhcp6-ia-pd-len>
    <blockpriv>1</blockpriv>
    <blockbogons>1</blockbogons>
    <media></media>
    <mediaopt></mediaopt>
    <disablechecksumoffloading/>
    <disablesegmentationoffloading/>
  </wan>
  <lan>
    <enable>1</enable>
    <descr>LAN</descr>
    <if>em1</if>
    <mtu></mtu>
    <lock/>
    <ipaddr>192.168.1.1</ipaddr>
    <subnet>24</subnet>
    <alias-address>192.168.1.2</alias-address>
    <alias-subnet>24</alias-subnet>
    <dhcphostname></dhcphostname>
    <dhcp6-ia-pd-len>0</dhcp6-ia-pd-len>
    <media></media>
    <mediaopt></mediaopt>
  </lan>
  <wifi>
    <enable>1</enable>
    <descr>Wireless</descr>
    <if>ath0</if>
    <mtu></mtu>
    <dhcphostname></dhcphostname>
    <dhcp6-ia-pd-len>0</dhcp6-ia-pd-len>
    <media></media>
    <mediaopt></mediaopt>
    <wireless>
      <mode>hostap</mode>
      <ssid>HomeNetwork</ssid>
      <channel>6</channel>
      <authmode>wpa2psk</authmode>
      <wpa_mode>wpa2</wpa_mode>
      <wpa_key_mgmt>WPA-PSK</wpa_key_mgmt>
      <wpa_pairwise>CCMP</wpa_pairwise>
      <passphrase>supersecretpsk</passphrase>
    </wireless>
  </wifi>
</interfaces>
