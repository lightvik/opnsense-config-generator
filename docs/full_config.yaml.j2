# ==============================================================================
# DNSMASQ — DNS Forwarder + DHCP сервер (default в OPNsense 26.x)
# ISC dhcpd удалён начиная с OPNsense 26.x; Kea DHCP — отдельный MVC-плагин.
# ==============================================================================
dnsmasq:
  enable: true
  port: "53053"                     # нестандартный порт — Unbound занимает 53
  interface: lan                    # интерфейс для привязки (lan, opt1, …)

  dhcp:
    enable_ra: true                 # IPv6 Router Advertisements

  dhcp_ranges:
    # IPv4 пул адресов для LAN
    - interface: lan
      start_addr: 192.168.1.100
      end_addr: 192.168.1.199

    # IPv6 пул адресов для LAN (суффикс в пределах delegated prefix)
    - interface: lan
      start_addr: "::1000"
      end_addr: "::2000"
      constructor: lan              # получить prefix от этого интерфейса
      ra_mode: slaac                # slaac | ra-only | ra-stateless | ra-names

    # DHCP для OPT-интерфейса:
    # - interface: opt1
    #   start_addr: 10.0.0.100
    #   end_addr: 10.0.0.199

  # regdhcp: false                  # регистрировать DHCP-аренды в dnsmasq DNS
  # regdhcpstatic: false            # регистрировать статические резервации
  # strict_order: false             # опрашивать upstream DNS серверы по порядку

# ==============================================================================
# UNBOUND DNS RESOLVER
# ==============================================================================
unbound:
  enable: true
  dnssec: true                      # включить DNSSEC-валидацию
  # forwarding: false               # пересылать запросы на upstream DNS
  # forward_tls_upstream: false     # использовать DNS-over-TLS для upstream
  # forward_servers: []             # upstream серверы (если forwarding=true)
  # active_interface: ""            # интерфейсы для listening (пусто = все)
  # outgoing_interface: ""          # интерфейсы для исходящих запросов
  # hide_identity: true
  # hide_version: true
  # prefetch: false                 # кэш-prefetch популярных записей
  # prefetch_key: false
  # dns64: false                    # DNS64 (для NAT64)
  # log_queries: false
  # cache_max_ttl: 86400
  # cache_min_ttl: 0
  # custom_options: ""              # сырые строки unbound.conf

  # Переопределения отдельных хостов:
  # hosts:
  #   - host: printer
  #     domain: home.local
  #     ip: 192.168.1.5
  #     descr: "Office printer"
  #   - host: nas
  #     domain: home.local
  #     ip: 192.168.1.20
  #     descr: "NAS storage"

  # Перенаправление домена на другой DNS:
  # domainoverrides:
  #   - domain: corp.example.com
  #     ip: 10.0.0.53
  #     descr: "Corporate DNS"
  #   - domain: ad.local
  #     ip: 192.168.1.250
  #     descr: "Active Directory DNS"

# ==============================================================================
# NTP (ntpd)
# Legacy-секция; настраивает chrony/ntpd прямо в config.xml.
# ==============================================================================
ntpd:
  servers:
    - address: 0.opnsense.pool.ntp.org
      pool: true                    # пул (ispool): несколько адресов за одним именем
      prefer: true                  # предпочитаемый источник
    - address: 1.opnsense.pool.ntp.org
      pool: true
    - address: 2.opnsense.pool.ntp.org
      pool: true
    - address: 3.opnsense.pool.ntp.org
      pool: true
    # Статический NTP-сервер (не пул):
    # - address: ntp.example.com
    #   pool: false
    #   prefer: false
    #   noselect: false             # не использовать для синхронизации (только мониторинг)

  # interface: ""                   # bind только на этот интерфейс (пусто = все)
  # orphan: 12                      # orphan stratum при отсутствии upstream

# ==============================================================================
# PKI — сертификаты и центры сертификации
# crt и prv — base64-encoded PEM (base64 -w0 < cert.pem)
# Примечание: caref в cert ссылается на поле descr CA-записи.
# ==============================================================================
certs:
  # Корневой CA:
  ca:
    - descr: "My Root CA"
      crt: "LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t..."   # base64(PEM)
      prv: "LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t..."   # base64(PEM)
      serial: 1

    # Промежуточный CA (caref = descr родительского CA):
    # - descr: "Intermediate CA"
    #   crt: "LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t..."
    #   prv: "LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t..."
    #   caref: "My Root CA"
    #   serial: 1

  # Серверные/клиентские сертификаты:
  cert:
    - descr: "VPN Server Cert"
      crt: "LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t..."
      prv: "LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t..."
      caref: "My Root CA"           # descr CA, которым подписан (пусто = self-signed)

    # - descr: "WebGUI Cert"
    #   crt: "LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t..."
    #   prv: "LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t..."
    #   caref: "My Root CA"

# ==============================================================================
# WIREGUARD (MVC-плагин, //OPNsense/wireguard)
# peers в server задаются именами клиентов — UUID резолвится автоматически.
# ==============================================================================
wireguard:
  enabled: true

  servers:
    - name: wg0
      privkey: "cHJpdmF0ZWtleWhlcmUxMjM0NTY3ODkwYWJjZGVmZ2g="   # base64 WG private key
      pubkey:  "cHVibGlja2V5aGVyZTEyMzQ1Njc4OTBhYmNkZWZnaA=="    # base64 WG public key
      port: "51820"
      tunneladdress:
        - "10.0.0.1/24"             # IP туннельного интерфейса сервера
      peers:
        - laptop                    # имена клиентов из секции clients ниже
        - phone
      # mtu: 1420
      # dns: []
      # disableroutes: false        # не добавлять маршруты автоматически
      # gateway: ""
      # description: "Main WireGuard server"
      # enabled: true

  clients:
    - name: laptop
      pubkey: "bGFwdG9wUHViS2V5SGVyZTEyMzQ1Njc4OTBhYmM="
      tunneladdress:
        - "10.0.0.2/32"
      # psk: ""                     # pre-shared key (base64)
      # serveraddress: ""           # для road warrior: адрес сервера
      # serverport: "51820"
      # keepalive: 25               # секунды
      # description: ""

    - name: phone
      pubkey: "cGhvbmVQdWJLZXlIZXJlMTIzNDU2Nzg5MGFiY2Q="
      tunneladdress:
        - "10.0.0.3/32"
      keepalive: 25

# ==============================================================================
# OPENVPN (MVC-плагин, //OPNsense/OpenVPN)
# ==============================================================================
openvpn:
  # Статические ключи (tls-auth / tls-crypt):
  # static_keys:
  #   - mode: crypt                 # auth | crypt
  #     description: "TLS key wg0"
  #     key: |
  #       -----BEGIN OpenVPN Static key V1-----
  #       ...
  #       -----END OpenVPN Static key V1-----

  instances:
    - description: "Road Warrior VPN"
      role: server                  # server | client
      dev_type: tun                 # tun | tap
      proto: udp                    # udp | udp4 | udp6 | tcp | tcp4 | tcp6
      port: "1194"
      server: "10.8.0.0/24"        # пул адресов для клиентов
      # server_ipv6: ""
      topology: subnet              # subnet | net30 | p2p
      ca: "My Root CA"              # descr CA из секции certs
      cert: "VPN Server Cert"       # descr сертификата из секции certs
      # tls_key: ""                 # description StaticKey
      verify_client_cert: require   # require | none
      # remote_cert_tls: false
      auth: "SHA256"
      data_ciphers:
        - AES-256-GCM
        - AES-128-GCM
        - CHACHA20-POLY1305
      data_ciphers_fallback: "AES-256-CBC"
      push_route:
        - "192.168.1.0/24"         # маршруты, передаваемые клиентам
      dns_servers:
        - 192.168.1.1
      keepalive_interval: 10
      keepalive_timeout: 60
      # maxclients: 100
      verb: "3"
      # redirect_gateway: []       # "def1", "ipv6", "bypass-dhcp", …
      # various_flags: []          # "persist-key", "persist-tun", …
      # local: ""                  # bind address (пусто = все интерфейсы)
      # enabled: true

    # Пример клиентского подключения:
    # - description: "Site-to-site client"
    #   role: client
    #   dev_type: tun
    #   proto: udp
    #   port: "1194"
    #   remote: "vpn.example.com"
    #   ca: "My Root CA"
    #   cert: "VPN Server Cert"
    #   data_ciphers:
    #     - AES-256-GCM

# ==============================================================================
# IPSEC (MVC-плагин, //OPNsense/Swanctl)
# Структура: connection → local/remote auth → child SA (туннели).
# connection в local/remote/children задаётся через description соединения.
# ==============================================================================
ipsec:
  connections:
    - description: "Site-to-Site VPN"
      version: "2"                  # "0"=IKEv1+v2 | "1"=IKEv1 | "2"=IKEv2
      local_addrs: "203.0.113.1"    # наш внешний IP (пусто = любой)
      remote_addrs: "198.51.100.1"  # IP удалённой стороны
      proposals: "default"          # IKE proposals (default = стандартный набор)
      unique: "no"                  # no | never | keep | replace
      mobike: true                  # MOBIKE (IKEv2 mobility)
      # reauth_time: 3600           # реаутентификация (сек)
      # rekey_time: 14400           # повторная генерация ключа (сек)
      # dpd_delay: 30               # Dead Peer Detection интервал (сек)
      # dpd_timeout: 150            # DPD таймаут (сек)
      # encap: false                # NAT-T (UDP encapsulation)
      # send_certreq: true
      # keyingtries: 0              # 0 = бесконечно
      # pools: []                   # имена пулов из секции pools
      # enabled: true

  # Аутентификация нашей стороны:
  locals:
    - connection: "Site-to-Site VPN"   # description соединения выше
      auth: psk                        # psk | pubkey | eap-tls | eap-mschapv2
      id: "203.0.113.1"               # наш IKE identity
      # round: 0
      # eap_id: ""
      # certs: []                      # certref для pubkey/eap-tls
      # description: ""
      # enabled: true

  # Аутентификация удалённой стороны:
  remotes:
    - connection: "Site-to-Site VPN"
      auth: psk
      id: "198.51.100.1"
      # round: 0
      # eap_id: ""
      # certs: []
      # cacerts: []
      # description: ""
      # enabled: true

  # Child SA — туннели (ESP):
  children:
    - connection: "Site-to-Site VPN"
      description: "LAN-to-LAN"
      local_ts:
        - "192.168.1.0/24"         # наша подсеть
      remote_ts:
        - "10.10.0.0/24"           # удалённая подсеть
      esp_proposals: "default"
      mode: tunnel                 # tunnel | transport | pass | drop
      start_action: start          # none | route | start | trap
      close_action: none           # none | trap | start
      dpd_action: clear            # clear | trap | start
      rekey_time: 3600
      # policies: true
      # sha256_96: false
      # reqid: null
      # enabled: true

  # IP-пулы для VPN-клиентов (Road Warrior):
  # pools:
  #   - name: "roadwarrior_pool"
  #     addrs: "10.20.0.0/24"
  #     dns:
  #       - 192.168.1.1
  #     enabled: true

