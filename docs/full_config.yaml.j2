# ==============================================================================
# CRON (MVC-плагин, //OPNsense/cron)
# origin: "cron" — системные задачи; используйте "cron" для пользовательских.
# ==============================================================================
cron:
  jobs:
    - origin: cron
      enabled: true
      minutes: "0"
      hours: "4"
      days: "*"
      months: "*"
      weekdays: "*"
      who: root
      command: "firmware update"
      description: "Daily firmware update check"
      # parameters: ""                # дополнительные аргументы команды

    # Запуск в первый день каждого месяца в 03:30:
    # - origin: cron
    #   enabled: false
    #   minutes: "30"
    #   hours: "3"
    #   days: "1"
    #   months: "*"
    #   weekdays: "*"
    #   who: root
    #   command: "firmware changelog"
    #   parameters: "verbose"
    #   description: "Monthly changelog fetch"

    # Запуск каждый понедельник в 02:00:
    # - origin: cron
    #   enabled: true
    #   minutes: "0"
    #   hours: "2"
    #   days: "*"
    #   months: "*"
    #   weekdays: "1"                 # 0=Sun, 1=Mon, …, 7=Sun
