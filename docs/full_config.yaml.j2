# ==============================================================================
# ACME CLIENT (MVC-плагин, //OPNsense/AcmeClient)
# Автоматическое получение и обновление TLS-сертификатов (Let's Encrypt и др.).
# Структура: settings → accounts → validations → certificates → actions.
# ==============================================================================
acme_client:
  settings:
    enabled: true
    environment: prod                 # prod | stg (stg = staging / тестовый CA)
    log_level: normal                 # normal | extended | debug | debug2 | debug3
    # auto_renewal: true              # глобальное авто-обновление
    # challenge_port: 43580           # порт для HTTP-01 challenge
    # tls_challenge_port: 43581       # порт для TLS-ALPN-01 challenge
    # restart_timeout: 600            # таймаут перезапуска (сек)

  # ACME-аккаунты (регистрация у CA):
  accounts:
    - name: letsencrypt
      email: admin@example.com
      ca: letsencrypt                 # buypass | buypass_test | google | google_test |
                                      # letsencrypt | letsencrypt_test | sslcom | zerossl | custom
      # enabled: true
      # description: ""
      # custom_ca: ""                 # URL для ca: custom
      # eab_kid: ""                   # External Account Binding (ZeroSSL и др.)
      # eab_hmac: ""

  # Методы проверки владения доменом:
  validations:
    - name: cloudflare-dns
      method: dns01                   # http01 | dns01 | tlsalpn01
      dns_service: dns_cf             # провайдер DNS (dns_cf, dns_aws, dns_gd, …)
      dns_sleep: 30                   # ожидание после обновления DNS (сек)
      dns_credentials:                # учётные данные для DNS API (зависят от провайдера)
        dns_cf_token: "mytoken123"    # для Cloudflare — API Token
      # enabled: true
      # description: ""

    # HTTP-01 challenge (порт 80):
    # - name: http-challenge
    #   method: http01
    #   description: "HTTP validation"

    # AWS Route53:
    # - name: route53-dns
    #   method: dns01
    #   dns_service: dns_aws
    #   dns_sleep: 30
    #   dns_credentials:
    #     dns_aws_access_key_id: "AKIAIOSFODNN7EXAMPLE"
    #     dns_aws_secret_access_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
    #     dns_aws_region: "us-east-1"

  # Сертификаты:
  certificates:
    - name: example.com
      account: letsencrypt            # имя аккаунта выше
      validation_method: cloudflare-dns   # имя validation выше
      alt_names:                      # Subject Alternative Names
        - www.example.com
        - mail.example.com
      key_length: key_4096            # key_2048 | key_3072 | key_4096 | key_ec256 | key_ec384
      auto_renewal: true
      renew_interval: 60              # обновлять за N дней до истечения
      # enabled: true
      # description: ""
      # ocsp: false                   # OCSP stapling
      # restart_actions: []           # имена actions для запуска после обновления
      # aliasmode: none               # none | automatic | domain | challenge
      # domain_alias: ""
      # challenge_alias: ""

  # Действия после обновления сертификата:
  actions:
    - name: restart-gui
      type: configd_restart_gui       # тип действия (configd_restart_gui, configd_restart, …)
      # enabled: true
      # description: ""
      # extra_params: {}              # дополнительные параметры (зависят от type)

    # Перезапуск произвольного сервиса:
    # - name: restart-haproxy
    #   type: configd_restart
    #   extra_params:
    #     service: haproxy

# ==============================================================================
# BIND DNS SERVER (MVC-плагин, //OPNsense/bind)
# Полноценный authoritative + recursive DNS сервер.
# ACL-имена используются в recursion, allowtransfer, allowquery доменов.
# ==============================================================================
bind:
  general:
    enabled: true
    port: 53530                       # порт (53530 чтобы не конфликтовать с Unbound)
    forwarders:
      - 8.8.8.8
      - 1.1.1.1
    dnssecvalidation: "no"            # "no" | "auto"
    rndcsecret: "VxtIzJevSQXqnr7h2qerrcwjnZlMWSGGFBndKeNIDfw="  # ключ rndc (base64)
    recursion:
      - local_nets                    # ACL-имена которым разрешена рекурсия
    # disablev6: false                # отключить IPv6
    # enablerpz: true                 # включить Response Policy Zone
    # listenv4: ["0.0.0.0"]           # IPv4-адреса для прослушивания
    # listenv6: ["::"]                # IPv6-адреса для прослушивания
    # filteraaaav4: false             # фильтровать AAAA-ответы для IPv4-клиентов
    # maxcachesize: 80                # % RAM для кэша
    # logsize: 5                      # размер лог-файла (MB)
    # general_log_level: info         # crit | error | warn | notice | info | debug | dynamic
    # allowtransfer: []               # ACL кому разрешена зонная передача
    # allowquery: []                  # ACL кому разрешены запросы (пусто = all)
    # hidehostname: false
    # hideversion: false
    # disableprefetch: false
    # enableratelimiting: false
    # ratelimitcount: null            # запросов/сек (null = без ограничений)
    # ratelimitexcept: ["0.0.0.0", "::"]
    # rndcalgo: hmac-sha256           # hmac-sha512 | hmac-sha384 | hmac-sha256 | …
    # querysource: ""                 # исходящий IP для запросов
    # transfersource: ""              # исходящий IP для зонных передач

  # Списки контроля доступа:
  acls:
    - name: local_nets
      networks:
        - 192.168.0.0/24
        - 10.0.0.0/8
      # enabled: true

    # - name: trusted_clients
    #   networks:
    #     - 192.168.1.0/24

  # DNS-зоны:
  domains:
    - domainname: home.local
      type: primary                   # primary | secondary | forward
      ttl: 86400
      allowquery:
        - local_nets                  # ACL-имена
      # enabled: true
      # allowtransfer: []
      # primaryip: []                 # IP primary серверов (для secondary зоны)
      # forwardserver: []             # IP форвардинга (для forward зоны)
      # serial: ""                    # номер серии (пусто = авто)
      # refresh: 21600
      # retry: 3600
      # expire: 3542400
      # negative: 3600
      # mailadmin: "mail.opnsense.localdomain"
      # dnsserver: "opnsense.localdomain"
      # allowrndctransfer: false
      # allowrndcupdate: true
      # allownotifysecondary: []
      # transferkeyalgo: ""
      # transferkeyname: ""
      # transferkey: ""

  # DNS-записи:
  records:
    - domain: home.local
      name: router
      type: A                         # A | AAAA | CNAME | MX | NS | PTR | TXT | SRV | …
      value: 192.168.0.1
      # enabled: true

    - domain: home.local
      name: nas
      type: A
      value: 192.168.0.10

    # AAAA:
    # - domain: home.local
    #   name: router
    #   type: AAAA
    #   value: "2001:db8::1"

    # CNAME:
