# ==============================================================================
# MONIT (MVC-плагин, //OPNsense/Monit)
# Мониторинг служб с автоматическим перезапуском и оповещением.
# Сервисы ссылаются на тесты по имени — UUID резолвится автоматически.
# ==============================================================================
monit:
  general:
    enabled: true
    interval: 60                      # интервал проверки (сек)
    startdelay: 30                    # задержка запуска monit после старта системы (сек)
    mailserver: "smtp.example.com"    # SMTP сервер для оповещений
    port: 587
    username: "monit@example.com"
    password: "secret"
    ssl: true
    sslversion: tlsv12                # auto | tlsv1 | tlsv11 | tlsv12 | tlsv13
    # sslverify: true                 # проверять TLS-сертификат сервера
    logfile: syslog facility log_daemon
    # statefile: ""                   # файл для хранения состояния
    httpd_enabled: true               # включить встроенный HTTP-интерфейс monit
    httpd_username: admin
    httpd_password: "adminpass"
    httpd_port: 2812
    httpd_allow:                      # список разрешённых IP/сетей
      - localhost
      - 192.168.1.0/24
    # eventqueue_path: ""             # каталог очереди событий
    # eventqueue_slots: null          # размер очереди (null = без ограничений)
    # mmonit_url: ""                  # URL M/Monit сервера
    # mmonit_timeout: 5
    # mmonit_register_credentials: true

  # Получатели оповещений:
  alerts:
    - enabled: true
      recipient: "admin@example.com"
      noton: false                    # false = слать при событиях; true = слать при отсутствии событий
      events:                         # события для оповещения (пусто = все)
        - connection
        - timeout
        - nonexist
      description: "Admin alert"
      # format: ""                    # шаблон письма
      # reminder: null                # повторять оповещение каждые N проверок

  # Тесты (условия мониторинга), на которые ссылаются сервисы:
  tests:
    - name: "CPU check"
      type: SystemResource            # Existence | SystemResource | ProcessResource |
                                      # ProcessDiskIO | Connection | NetworkInterface | …
      condition: "cpu > 80% for 5 cycles"
      action: alert                   # alert | restart | start | stop | exec | unmonitor

    - name: "Memory check"
      type: SystemResource
      condition: "memory usage > 90%"
      action: alert

    - name: "Nginx connection"
      type: Connection
      condition: "failed port 80 protocol http"
      action: restart

    # - name: "Disk space"
    #   type: SpaceUsage
    #   condition: "space usage > 85%"
    #   action: alert

    # - name: "Ping check"
    #   type: NetworkPing
    #   condition: "failed ping count 3 with timeout 5 seconds"
    #   action: alert

  # Мониторируемые сервисы:
  services:
    - enabled: true
      name: "system"
      type: system                    # system | process | file | filesystem | host | network | custom
      tests:
        - "CPU check"
        - "Memory check"
      description: "System resource monitoring"

    - enabled: true
      name: "nginx"
      type: process
      pidfile: "/var/run/nginx.pid"
      start: "/usr/sbin/service nginx start"
      stop: "/usr/sbin/service nginx stop"
      tests:
        - "Nginx connection"
      depends:
        - "system"                    # имена сервисов-зависимостей
      description: "Nginx web server"
      # match: ""                     # regexp-паттерн для поиска процесса (вместо pidfile)
      # timeout: 300                  # таймаут запуска/остановки (сек)
      # starttimeout: 30
      # polltime: ""                  # индивидуальный интервал проверки

    # Мониторинг хоста:
    # - enabled: true
    #   name: "gateway"
    #   type: host
    #   address: 8.8.8.8
    #   tests:
    #     - "Ping check"
    #   description: "Internet connectivity check"

    # Мониторинг файловой системы:
    # - enabled: true
    #   name: "rootfs"
    #   type: filesystem
    #   path: "/"
    #   tests:
    #     - "Disk space"
    #   description: "Root filesystem"

# ==============================================================================
# TRAFFIC SHAPER (MVC-плагин, //OPNsense/TrafficShaper)
# Иерархия: pipe → queue → rule.
# Правила ссылаются на pipe/queue по description — UUID резолвится автоматически.
# ==============================================================================
trafficshaper:
  # Pipes — каналы с ограничением полосы:
  pipes:
    - number: 1
      description: "WAN Download"
      bandwidth: 100
      bandwidth_metric: Mbit         # bit | Kbit | Mbit | Gbit
      mask: none                     # none | src-ip | dst-ip | src-ip6 | dst-ip6
      # enabled: true
      # queue: null                  # размер очереди (пакетов)
      # buckets: null                # hash-таблица для per-flow шейпинга
      # scheduler: ""                # "" | fifo | rr | qfq | fq_codel | fq_pie
      # delay: null                  # задержка (мс)
      # codel_enable: false
      # pie_enable: false
      # origin: ""

    - number: 2
      description: "WAN Upload"
      bandwidth: 20
      bandwidth_metric: Mbit
      mask: none

  # Queues — очереди внутри pipe с весами:
  queues:
    - number: 1
      description: "WAN High Priority"
      pipe: "WAN Download"           # description родительского pipe
      weight: 70                     # относительный вес (сумма не обязана быть 100)
      # enabled: true
      # mask: none
      # buckets: null
      # codel_enable: false
      # pie_enable: false
      # origin: ""

    - number: 2
      description: "WAN Low Priority"
      pipe: "WAN Download"
      weight: 30

  # Rules — правила назначения трафика на pipe/queue:
  rules:
    - sequence: 1
      interface: wan
      proto: tcp                     # ip | ip4 | ip6 | udp | tcp | icmp | …
      source: any                    # any | IP | subnet
      destination: any
      dst_port: "80,443"             # порт / список / диапазон "80:443"
      direction: in                  # "" | in | out
      target_queue: "WAN High Priority"  # description очереди (или target_pipe)
      description: "Prioritize web traffic"
      # enabled: true
      # source_not: false            # инвертировать источник
      # destination_not: false
      # src_port: any
      # interface2: ""               # второй интерфейс (для двунаправленных правил)
      # iplen: null                  # фильтр по размеру IP-пакета
      # dscp: []                     # фильтр по DSCP-меткам

    - sequence: 100
      interface: wan
      proto: ip
      source: any
      destination: any
      target_pipe: "WAN Download"    # description pipe (вместо target_queue)
      description: "Default WAN Download shaping"

    # - sequence: 200
    #   interface: wan
    #   proto: ip
    #   source: any
    #   destination: any
    #   target_pipe: "WAN Upload"
    #   direction: out
    #   description: "Default WAN Upload shaping"

# ==============================================================================
# RADVD — Router Advertisement Daemon (MVC-плагин, //OPNsense/radvd)
# IPv6 Router Advertisements. Режимы:
#   router    — полноценный IPv6 gateway (stateful DHCPv6)
#   unmanaged — только RA без DHCPv6
#   managed   — managed (клиенты берут адрес по DHCPv6)
#   assist    — помощник (работает совместно с другим RA)
#   stateless — stateless autoconfiguration (SLAAC)
# ==============================================================================
radvd:
  entries:
    - interface: lan
      mode: stateless                # router | unmanaged | managed | assist | stateless
      rdnss:
        - "2001:db8::1"             # DNS-серверы для клиентов
      dnssl:
        - "home.local"              # суффиксы поиска DNS
      adv_link_mtu: 1500            # MTU для клиентов
      adv_valid_lifetime: 86400     # время жизни prefix (сек)
      adv_preferred_lifetime: 14400
      # enabled: true
      # base6_interface: ""         # источник prefix (пусто = собственный)
      # min_rtr_adv_interval: 200   # мин. интервал RA (сек)
      # max_rtr_adv_interval: 600   # макс. интервал RA (сек)
      # adv_default_preference: medium   # low | medium | high
      # adv_default_lifetime: null  # время жизни шлюза по умолчанию (сек)
      # adv_rdnss_lifetime: null    # время жизни RDNSS
      # adv_dnssl_lifetime: null    # время жизни DNSSL
      # adv_route_lifetime: null
      # adv_ra_src_address: ""      # IP-адрес источника RA
      # routes: []                  # дополнительные маршруты для рекламы
      # nat64prefix: ""             # NAT64 prefix (RFC 8781)
      # adv_cur_hop_limit: 64
      # dns: true                   # включать RDNSS/DNSSL в RA
      # deprecate_prefix: null      # on | off
      # remove_adv_on_exit: null    # on | off
      # remove_route: null          # on | off

    # Managed-режим (DHCPv6):
    # - interface: opt1
    #   mode: managed
    #   enabled: true
    #   max_rtr_adv_interval: 300
    #   adv_default_preference: high

