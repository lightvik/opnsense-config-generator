{# =============================================================================
   opnsense-config-generator — docs/full_config.yaml.j2
   Документированный полный шаблон конфигурации OPNsense.
   Содержит все поддерживаемые секции с описанием каждого параметра.

   Это справочный файл. Рабочий шаблон для редактирования — config.yaml.j2
   в корне проекта. Минимальная конфигурация — docs/minimal_config.yaml.j2.

   JINJA2 ВОЗМОЖНОСТИ
   ------------------
   • env — словарь переменных окружения:
         hostname: {{ env.MY_HOSTNAME }}
         hostname: {{ env.get('MY_HOSTNAME', 'fw01') }}
   • load_yaml('path.yaml') — загрузить внешний YAML (для secrets и т.д.):
         {% set secrets = load_yaml('/etc/opnsense-secrets.yaml') %}
         password: {{ secrets.admin_password }}
   • Полный синтаксис Jinja2: условия ({% if %} / {% endif %}),
     циклы ({% for %} / {% endfor %}), фильтры ({{ val | default('x') }}).

   СТРУКТУРА ФАЙЛА
   ---------------
   • Обязательные поля — без комментария.
   • Опциональные поля — закомментированы с примерами и пояснениями.
   • Значения по умолчанию показаны в комментарии после поля.
   ============================================================================= #}

# ==============================================================================
# SYSTEM
# ==============================================================================
system:
  hostname: OPNsense                # имя хоста (без домена)
  domain: internal                  # домен

  # DNS-серверы (добавляются в /etc/resolv.conf и forwarding unbound)
  dnsserver:
    - 8.8.8.8
    - 8.8.4.4

  # Разрешить провайдеру переопределять DNS через DHCP (1 = да)
  # dnsallowoverride: true

  timezone: Etc/UTC                 # TZ-database name (Europe/Moscow, UTC, …)

  # NTP-серверы системного уровня (строка через пробел, или список строк).
  # Используется system ntp, а не ntpd-секция (см. ниже). Обычно не нужно.
  # timeservers: "0.opnsense.pool.ntp.org 1.opnsense.pool.ntp.org"

  # Оптимизация pf: normal | high-latency | aggressive | conservative
  # optimization: normal

  # -----------------------------------------------------------------------
  # WEB GUI
  # -----------------------------------------------------------------------
  webgui:
    protocol: https                 # http | https
    # port: ""                      # пустая строка = 443/80 по умолчанию
    # interfaces: ""                # пустая строка = все интерфейсы
    # nohttpreferercheck: false     # отключить проверку HTTP Referer
    # loginautocomplete: false      # разрешить автозаполнение формы входа
    # ssl_certref: ""               # refid сертификата из секции certs

  # -----------------------------------------------------------------------
  # SSH
  # -----------------------------------------------------------------------
  ssh:
    enabled: false                  # true = включить SSH-демон
    group: admins                   # группа, которой разрешён SSH-доступ
    # permitrootlogin: false        # разрешить root login по SSH
    # passwordauth: true            # разрешить аутентификацию по паролю

  # -----------------------------------------------------------------------
  # ПОЛЬЗОВАТЕЛИ
  # Пароль указывается plaintext — в XML пишется bcrypt-хэш.
  # Если пароль уже хэширован ($2b$...) — используется как есть.
  # -----------------------------------------------------------------------
  users:
    - name: root
      password: "opnsense"          # ЗАМЕНИТЕ на свой пароль
      descr: System Administrator
      scope: system                 # system | user
      groupname: admins
      uid: 0
      shell: /bin/sh
      # expires: ""                 # дата истечения: MM/DD/YYYY или пусто

    # Дополнительный пользователь:
    # - name: alice
    #   password: "s3cr3t"
    #   descr: Alice
    #   scope: user
    #   groupname: admins
    #   uid: 2000
    #   shell: /bin/sh

  # -----------------------------------------------------------------------
  # ГРУППЫ
  # -----------------------------------------------------------------------
  groups:
    - name: admins
      description: System Administrators
      scope: system                 # system | group
      gid: 1999
      members: [0]                  # список uid пользователей
      priv: [page-all]              # привилегии (page-all = полный доступ)

    # Группа только для чтения:
    # - name: readonly
    #   description: Read-only operators
    #   scope: group
    #   gid: 2000
    #   members: [2000]
    #   priv: [page-dashboard-all, page-status-*]

  # Misc настройки (обычно менять не нужно)
  # disablenatreflection: "yes"     # yes | no
  # usevirtualterminal: true
  # disableconsolemenu: false
  # ipv6allow: true
  # pf_share_forward: true
  # lb_use_sticky: true
  # rrdbackup: -1
  # netflowbackup: -1

# ==============================================================================
# INTERFACES
# Ключ = имя назначения интерфейса: wan, lan, opt1, opt2, …
# ==============================================================================
interfaces:
  interfaces:
    wan:
      if: vtnet0                    # физический интерфейс (vtnet0, em0, igb0, …)
      ipaddr: dhcp                  # dhcp | статический IP | pppoe
      ipaddrv6: dhcp6               # dhcp6 | slaac | статический IPv6 | ""
      blockpriv: true               # блокировать RFC1918 с WAN
      blockbogons: true             # блокировать bogons с WAN
      # mtu: ""                     # MTU, пусто = авто
      # media: ""                   # скорость/дуплекс (autoselect, 1000baseT…)
      # mediaopt: ""
      # dhcphostname: ""            # имя хоста для DHCP-запроса
      # spoofmac: ""                # подменить MAC
      # dhcp6-ia-pd-len: 0          # длина prefix delegation (0-32)

    lan:
      if: vtnet1
      ipaddr: 192.168.1.1
      subnet: "24"                  # длина маски (без слэша)
      ipaddrv6: idassoc6            # idassoc6 = использовать delegated prefix от WAN
      subnetv6: "64"
      track6-interface: wan         # WAN-интерфейс с prefix delegation
      track6-prefix-id: 0

    # Пример OPT-интерфейса со статическим IP:
    # opt1:
    #   if: vtnet2
    #   descr: DMZ
    #   ipaddr: 10.0.0.1
    #   subnet: "24"
    #   ipaddrv6: ""

    # Пример PPPoE на WAN:
    # wan:
    #   if: vtnet0
    #   ipaddr: pppoe
    #   username: user@provider.ru
    #   password: pppoe_password
    #   pppoe-reset-type: ""        # "" | custom | preset

