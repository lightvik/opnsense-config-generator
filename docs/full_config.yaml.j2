# ==============================================================================
# FIREWALL RULES
# ==============================================================================
filter:
  rules:
    # Разрешить весь трафик с LAN наружу (IPv4)
    - type: pass
      ipprotocol: inet
      interface: lan
      descr: Default allow LAN to any rule
      source:
        network: lan               # lan | wan | opt1 | IP/маска | имя алиаса
      destination:
        any: true

    # Разрешить весь трафик с LAN наружу (IPv6)
    - type: pass
      ipprotocol: inet6
      interface: lan
      descr: Default allow LAN IPv6 to any rule
      source:
        network: lan
      destination:
        any: true

    # Пример блокирующего правила:
    # - type: block
    #   ipprotocol: inet
    #   interface: lan
    #   descr: Block social media
    #   protocol: tcp
    #   source:
    #     network: lan
    #   destination:
    #     address: 157.240.0.0/16
    #     port: "443"
    #   log: true

    # Пример правила с алиасом:
    # - type: block
    #   ipprotocol: inet
    #   interface: lan
    #   descr: Block RFC1918 from DMZ
